{
    // still use Prettier as your formatter…
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    // …but run ESLint on save (or onType if you prefer)
    "eslint.run": "onSave",
    // enable ESLint diagnostics in TS/JS files
    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact"
    ],
    // actually apply ESLint fixes on save
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.fixAll.eslint": "explicit"
    },
    // optional: always show the ESLint status in the status bar
    "eslint.alwaysShowStatus": true
}